# --- Tero environment variables ---

# Supabase Postgres connection string (Prisma).
# Get this from Supabase: Project Settings -> Database -> Connection string -> URI.
# Use the pooled "Transaction" connection (port 6543) for serverless on Vercel,
# and add ?pgbouncer=true&connection_limit=1 for the pooled URL.
# The app pages still run without this; only the waitlist/session API routes need it.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"

# Optional: direct (non-pooled) connection used by `prisma migrate` (port 5432).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# GA only loads in the browser AFTER the visitor accepts the cookie consent banner.
# Leave empty to disable analytics entirely (trackEvent becomes a no-op).
NEXT_PUBLIC_GA_ID=""
