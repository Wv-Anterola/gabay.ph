// Tero Prisma schema (Prisma Postgres).
// The app pages run without a database; only the API routes
// (/api/waitlist, /api/session) require DATABASE_URL.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
  // Connection URL lives in prisma.config.ts (Prisma 7); the runtime
  // PrismaClient connects via the @prisma/adapter-pg driver adapter.
}

/// Waitlist + paid-interest capture from /waitlist.
model WaitlistSignup {
  id             String   @id @default(cuid())
  email          String   @unique
  gradeLevel     String? // e.g. "Grade 11", "Grade 12", "Gap year"
  targetYear     String? // intended UPCAT year, free text
  paidInterest   Boolean  @default(false) // interested in a future paid plan
  referralSource String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

/// A diagnostic attempt for one module (or a combined run).
/// Answers + computed scores are stored as JSON so the schema
/// stays stable as the scoring logic evolves.
model DiagnosticSession {
  id           String   @id @default(cuid())
  clientId     String? // anonymous localStorage id, not personally identifying
  module       String // "language" | "reading" | "math" | "science"
  answers      Json // { [questionId]: "a" | "b" | "c" | "d" }
  score        Json // serialized ModuleScore (correct, total, accuracy, topics)
  durationMs   Int?
  completedAt  DateTime @default(now())

  @@index([module])
  @@index([completedAt])
}

/// One submitted or in-progress full UPCAT mock exam attempt.
/// The app can run without this table; it is the durable analytics sink when
/// DATABASE_URL is configured.
model MockAttempt {
  id              String   @id
  clientId        String?
  status          String
  startedAt       DateTime
  submittedAt     DateTime?
  durationSeconds Int?
  remainingSeconds Int
  rawScore        Int?
  rawTotal        Int?
  weightedScore   Float?
  weightedTotal   Float?
  readinessScore  Int?
  sectionScores   Json?
  overallScore    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  responses MockQuestionResponse[]

  @@index([clientId])
  @@index([submittedAt])
  @@index([status])
}

/// Per-question response data for a mock attempt. This is the dataset used for
/// future recommendations and AI explanations.
model MockQuestionResponse {
  id               String   @id @default(cuid())
  attemptId        String
  questionId       String
  section          String
  topic            String
  difficulty       String
  selectedAnswer   String?
  correctAnswer    String
  isAnswered       Boolean
  isCorrect        Boolean
  isFlagged        Boolean
  timeSpentSeconds Int
  createdAt        DateTime @default(now())

  attempt MockAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([questionId])
  @@index([section])
  @@index([topic])
  @@index([difficulty])
  @@index([isCorrect])
}

/// Optional first-party mirror of analytics events.
/// GA4 is the primary analytics sink; this table is for
/// data ownership / direct querying and is written best-effort.
model AnalyticsEvent {
  id        String   @id @default(cuid())
  name      String
  props     Json?
  clientId  String?
  createdAt DateTime @default(now())

  @@index([name])
  @@index([createdAt])
}
