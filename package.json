    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.15",
    "prisma": "^7.8.0",
    "tailwindcss": "3.4.17",
    "tsx": "^4.22.4",
    "typescript": "5.7.3",
    "vitest": "^4.1.9"
